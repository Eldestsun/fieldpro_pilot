# OTEM Feature Flag
VITE_ENABLE_OTEM=false

# Dev auth bypass — NEVER set to true in production or any shared environment.
# When true AND MODE != production AND localStorage.__dev_user__ is set,
# the frontend accepts a synthetic MSAL account without a real Azure AD session.
# Symmetrical to backend DEV_AUTH_BYPASS. See docs/dev/dev-auth-bypass.md.
VITE_DEV_AUTH_BYPASS=false
