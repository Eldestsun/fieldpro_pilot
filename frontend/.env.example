# ── Azure Entra (MSAL) ────────────────────────────────────────────────────────
# All three are required. Without them, MSAL constructs "undefined/access_as_user"
# as the scope and auth fails silently.
VITE_AZURE_TENANT_ID=           # Azure Entra tenant ID (GUID)
VITE_AZURE_CLIENT_ID=           # Frontend app registration client ID (GUID)
VITE_API_APP_ID_URI=            # Backend app ID URI, e.g. api://<backend-client-id>

# Optional: override the MSAL redirect URI. Defaults to window.location.origin.
# VITE_REDIRECT_URI=https://baseline-frontend.onrender.com

# ── Map tiles ─────────────────────────────────────────────────────────────────
# Required for ULRouteMap. Leave unset to disable the map tile layer.
# VITE_MAPTILER_KEY=

# ── Feature flags ─────────────────────────────────────────────────────────────
VITE_ENABLE_OTEM=false

# ── Dev auth bypass ───────────────────────────────────────────────────────────
# NEVER set to true in production or any shared environment.
# When true AND MODE != production AND localStorage.__dev_user__ is set,
# the frontend accepts a synthetic MSAL account without a real Azure AD session.
VITE_DEV_AUTH_BYPASS=false
