# Database — individual vars (used by db.ts and migrate.ts)
PGHOST=localhost
PGPORT=5432
PGUSER=fieldpro
PGPASSWORD=fieldpro_pass
PGDATABASE=fieldpro_db
# or as a single connection string (takes precedence over PG* vars):
# DATABASE_URL=postgres://fieldpro:fieldpro_pass@localhost:5432/fieldpro_db

# Server
PORT=4000

# OSRM (routing engine)
OSRM_BASE_URL=http://localhost:5005

# Azure Entra (auth)
AZURE_TENANT_ID=
AZURE_API_AUDIENCE=
AZURE_CLIENT_ID=

# App roles (as defined in Entra App Registration)
APP_ROLE_ADMIN=Admin
APP_ROLE_LEAD=Lead
APP_ROLE_UL=UL

# Group GUIDs (only if wiring Entra groups instead of app roles)
ADMIN_GROUP_ID=
LEAD_GROUP_ID=
UL_GROUP_ID=

# MinIO / object storage
MINIO_ENDPOINT=localhost
MINIO_ACCESS_KEY_ID=fieldpro
MINIO_SECRET_ACCESS_KEY=
MINIO_BUCKET=fieldpro-uploads
MINIO_REGION=us-east-1

# Timezone
TZ=America/Los_Angeles

# S1-13 — OID encryption (dev only)
# Required for local dev and tests. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This key encrypts the per-record DEK (envelope encryption). See oidCipher.ts.
# In production: leave unset — the AzureKeyVaultAdapter uses AZURE_KEY_VAULT_URL instead.
DEV_OID_KEY=

# S1-13 — Azure Key Vault (production only, set after S3-1 hosting decision)
# AZURE_KEY_VAULT_URL=https://<vault-name>.vault.azure.net
# AZURE_KEY_VAULT_KEY_NAME=oid-kek

# Migration runner invocation (for reference — vars above cover this):
# PGPASSWORD=fieldpro_pass PGHOST=localhost PGUSER=fieldpro \
#   PGDATABASE=fieldpro_db npm run migrate

# ── S1-6 — SFTP Export Writer (nightly canonical-data snapshot) ───────────────
# SFTP_ENABLED controls whether the sftp:export script actually uploads.
# Set to "true" only after the SFTP destination is provisioned and tested.
# When unset or any value other than "true", the script writes local files
# only and exits cleanly — safe to wire the cron job before the server is ready.
SFTP_ENABLED=false

# Remote SFTP host and port (default 22).
SFTP_HOST=
SFTP_PORT=22

# SFTP username. Must have write access to SFTP_REMOTE_DIR.
SFTP_USER=

# Absolute path to the SSH private key file (PEM format, no passphrase).
# Key-based auth only — password auth is never attempted. See sftpExport.ts header.
# Provision the key out-of-band; never store the private key in the repo.
SFTP_PRIVATE_KEY_PATH=/etc/baseline/sftp_id_ed25519

# Absolute path to an SSH known_hosts file containing the server's host key.
# Strict host key checking: if the host key does not match, the script refuses
# to connect. Generate with: ssh-keyscan -p <port> <host> >> known_hosts
# Do NOT use -H (hashed entries are not supported — use plain known_hosts).
SFTP_KNOWN_HOSTS_PATH=/etc/baseline/sftp_known_hosts

# Remote directory where export bundles are written. Must exist and be writable.
# Example: /exports/baseline/incoming/
SFTP_REMOTE_DIR=

# Docker / containerized deployment
# Replace localhost with Docker service names from docker-compose.yml:
# PGHOST=db
# OSRM_BASE_URL=http://osrm:5005
# MINIO_ENDPOINT=minio
